## Resend email service (used by api/send-email.js)
## Sign up at https://resend.com and create an API key in the dashboard.
RESEND_API_KEY=re_your_api_key_here

## Optional: the "from" address shown on outgoing emails.
## - For testing, leave unset (defaults to onboarding@resend.dev).
## - For production, verify your sending domain in Resend, then set this to e.g.
##   "Bold Energy <no-reply@mail.boldenergy.com>"
RESEND_FROM=Bold Energy <onboarding@resend.dev>

## Cloudflare Turnstile — bot protection for the contact/lead forms.
## Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
## VITE_TURNSTILE_SITE_KEY is public (frontend); TURNSTILE_SECRET_KEY is server-only.
## For local dev you can use Cloudflare's TEST keys (always pass):
##   VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
##   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

## Optional: restrict the API to your own domain(s). Comma-separated hostnames.
## Leave unset to disable the check (CAPTCHA is the primary gate).
# ALLOWED_ORIGINS=boldenergy.com,www.boldenergy.com
